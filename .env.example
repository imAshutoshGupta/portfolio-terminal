# --- Spotify "Now Playing" (optional) ---
# Without these, /api/now-playing returns the same simulated track list the
# preview uses, so the widget looks identical out of the box.
# Create an app at https://developer.spotify.com/dashboard, then run the
# auth-code flow once to get a long-lived refresh token with scope
# user-read-currently-playing user-read-recently-played.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# --- GitHub live stats (optional) ---
# Without a token, /api/github falls back to the static numbers from the design.
# A classic or fine-grained PAT with public read access is enough.
GITHUB_TOKEN=
GITHUB_USERNAME=imAshutoshGupta

# --- Contact form (optional) ---
# Where /api/contact delivers messages. Without it, the endpoint logs + 200s.
CONTACT_TO_EMAIL=hello@ashutoshgupta.dev
RESEND_API_KEY=
